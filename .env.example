# Absolute host path mounted into the API container for local project indexing
HOST_PROJECTS_ROOT=/Users/your-user/projects

POSTGRES_DB=codecompass
POSTGRES_USER=codecompass
POSTGRES_PASSWORD=codecompass

NEO4J_USER=neo4j
NEO4J_PASSWORD=research123

AUTO_REINDEX_INTERVAL_SECONDS=60
DEFAULT_POLL_INTERVAL_SECONDS=60
MAX_GRAPH_NODES_FULL_VIEW=3000
MAX_GRAPH_EDGES_FULL_VIEW=7000
AST_EXCLUDED_DIRNAMES=.git,__pycache__,venv,.venv,site-packages,node_modules,dist,build,.mypy_cache,.pytest_cache,.tox
MCP_DEFAULT_TRANSPORT=streamable-http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8811
MCP_HTTP_PATH=/mcp
MCP_HTTP_PUBLIC_URL=http://localhost:8811/mcp
MCP_HTTP_STATELESS=true
